# Required — generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# App URL (auto-set on Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database — PostgreSQL (Vercel Postgres, Neon, Supabase, or local)
# For local SQLite testing, use a Postgres Docker container or free Neon DB
DATABASE_URL=postgresql://user:password@localhost:5432/enabler

# Optional — enhanced translation gloss via OpenAI
OPENAI_API_KEY=
